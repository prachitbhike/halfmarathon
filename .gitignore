# Results — committed selectively, raw runs ignored
# (per-dim state-dirs, summary JSONs, nested sqlite checkpoints)
results/runs/
results/dim*/
results/**/*.json
results/**/*.sqlite
!results/.gitkeep
!results/README.md
# The rendered matrix is THE committed artifact:
!results/eval-matrix.md

# Implementation-local state
implementations/*/state/
implementations/*/state-*/
implementations/*/.checkpoints/
implementations/*/letta-data/
implementations/*/temporal-data/
implementations/*/postgres-data/

# e2b
.e2b/

